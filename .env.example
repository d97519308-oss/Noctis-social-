# Database
DATABASE_URL=postgresql://noctis:noctis_secure_pass@localhost:5432/noctis_social
REDIS_URL=redis://localhost:6379
MONGO_URL=mongodb://noctis:noctis_secure_pass@localhost:27017/noctis_social
ELASTICSEARCH_URL=http://localhost:9200

# API
API_PORT=3000
AUTH_PORT=3001
USER_PORT=3002
FEED_PORT=3003
MESSAGING_PORT=3004
NOTIFICATION_PORT=3005
MEDIA_PORT=3006
SEARCH_PORT=3007

NODE_ENV=development
API_URL=http://localhost:3000

# Security
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3008

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,mp3,pdf,doc,docx

# Email
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=noctis-social-uploads

# Monitoring
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info
